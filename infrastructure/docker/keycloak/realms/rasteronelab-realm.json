{
  "id": "rasteronelab",
  "realm": "rasteronelab",
  "displayName": "RasterOneLab LIS",
  "displayNameHtml": "<strong>RasterOneLab</strong> Lab Information System",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "rememberMe": true,
  "verifyEmail": false,
  "bruteForceProtected": true,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "offlineSessionMaxLifespan": 5184000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "actionTokenGeneratedByAdminLifespan": 43200,
  "actionTokenGeneratedByUserLifespan": 300,
  "defaultSignatureAlgorithm": "RS256",
  "roles": {
    "realm": [
      {
        "name": "SUPER_ADMIN",
        "description": "Full system access across all branches and organizations",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "ORG_ADMIN",
        "description": "Organization-level administrator with access to all branches within the organization",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "BRANCH_ADMIN",
        "description": "Branch-level administrator with full access within a single branch",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "PATHOLOGIST",
        "description": "Lab pathologist responsible for result validation and report authorization",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "LAB_TECHNICIAN",
        "description": "Lab technician responsible for sample processing and result entry",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "RECEPTIONIST",
        "description": "Front desk staff handling patient registration and order creation",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "PHLEBOTOMIST",
        "description": "Sample collection staff responsible for phlebotomy and specimen labeling",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "BILLING_STAFF",
        "description": "Billing and accounts staff managing invoices, payments, and financial reports",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "DOCTOR",
        "description": "Referring doctor with access to patient reports and order placement",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "PATIENT",
        "description": "Patient portal access for viewing reports and booking appointments",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "clients": [
    {
      "clientId": "lis-frontend",
      "name": "LIS Frontend Application",
      "description": "Angular 19 SPA for the RasterOneLab LIS",
      "enabled": true,
      "publicClient": true,
      "clientAuthenticatorType": "client-secret",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "redirectUris": [
        "http://localhost:4200/*"
      ],
      "webOrigins": [
        "http://localhost:4200"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:4200/*",
        "oauth2.device.authorization.grant.enabled": "false",
        "oidc.ciba.grant.enabled": "false",
        "login_theme": "keycloak"
      },
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "organizationId",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "organizationId",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "organizationId",
            "jsonType.label": "String",
            "multivalued": "false"
          }
        },
        {
          "name": "branchIds",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "branchIds",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "branchIds",
            "jsonType.label": "JSON",
            "multivalued": "true",
            "aggregate.attrs": "true"
          }
        },
        {
          "name": "employeeId",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "employeeId",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "employeeId",
            "jsonType.label": "String",
            "multivalued": "false"
          }
        }
      ]
    },
    {
      "clientId": "lis-backend",
      "name": "LIS Backend Services",
      "description": "Spring Boot backend microservices for the RasterOneLab LIS",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "lis-backend-secret-dev",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "redirectUris": [],
      "webOrigins": [],
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "false",
        "oidc.ciba.grant.enabled": "false"
      }
    }
  ],
