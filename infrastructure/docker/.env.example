# ===========================
# RasterOneLab LIS — Docker Environment Variables
# ===========================
# Copy this file to .env and fill in the values
# NEVER commit .env to git!

# PostgreSQL
DB_NAME=lisdb
DB_USER=lisadmin
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK_ADMIN_PASSWORD
KC_HOSTNAME=localhost

# RabbitMQ
RABBITMQ_USER=lisuser
RABBITMQ_PASSWORD=CHANGE_ME_RABBITMQ_PASSWORD
RABBITMQ_VHOST=/lis

# Elasticsearch
ELASTIC_PASSWORD=CHANGE_ME_ELASTIC_PASSWORD

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# Application
APP_VERSION=1.0.0-SNAPSHOT
ALLOWED_ORIGINS=http://localhost:4200
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_CLIENT_SECRET

# Notification (Mail — defaults point to Mailhog dev container)
MAIL_HOST=localhost
MAIL_PORT=1025

# Notification (Twilio — leave empty for dev)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# Service URLs (for docker-compose)
PATIENT_SERVICE_URL=http://lis-patient:8081
ORDER_SERVICE_URL=http://lis-order:8082
SAMPLE_SERVICE_URL=http://lis-sample:8083
RESULT_SERVICE_URL=http://lis-result:8084
REPORT_SERVICE_URL=http://lis-report:8085
BILLING_SERVICE_URL=http://lis-billing:8086
INVENTORY_SERVICE_URL=http://lis-inventory:8087
INSTRUMENT_SERVICE_URL=http://lis-instrument:8088
QC_SERVICE_URL=http://lis-qc:8089
ADMIN_SERVICE_URL=http://lis-admin:8090
NOTIFICATION_SERVICE_URL=http://lis-notification:8091
INTEGRATION_SERVICE_URL=http://lis-integration:8092
AUTH_SERVICE_URL=http://lis-auth:8093
