pipeline {
    agent any

    environment {
        APP_NAME = 'rasteronelab-lis'
        DOCKER_REGISTRY = 'registry.rasterwebapps.com'
        SONARQUBE_SERVER = 'SonarQube'
        NEXUS_CREDENTIALS = credentials('nexus-credentials')
        DOCKER_CREDENTIALS = credentials('docker-registry')
        KUBECONFIG = credentials('k8s-config')
    }

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'staging', 'production'], description: 'Deployment environment')
        string(name: 'MODULE', defaultValue: 'all', description: 'Module to build (all or specific module name)')
        booleanParam(name: 'SKIP_TESTS', defaultValue: false, description: 'Skip unit tests')
        booleanParam(name: 'DEPLOY', defaultValue: true, description: 'Deploy after build')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.GIT_COMMIT_SHORT = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
                    env.IMAGE_TAG = "${env.BUILD_NUMBER}-${env.GIT_COMMIT_SHORT}"
                    echo "Building: ${APP_NAME}:${env.IMAGE_TAG}"
                }
            }
        }

        stage('Build Backend') {
            steps {
                dir('backend') {
                    sh '''
                        chmod +x gradlew
                        ./gradlew clean build -x test --no-daemon --parallel --build-cache
                    '''
                }
            }
        }

        stage('Run Tests') {
            when {
                expression { !params.SKIP_TESTS }
            }
            parallel {
                stage('Backend Unit Tests') {
                    steps {
                        dir('backend') {
                            sh './gradlew test jacocoTestReport jacocoTestCoverageVerification --no-daemon --build-cache'
                        }
                    }
                    post {
                        always {
                            junit 'backend/**/build/test-results/test/*.xml'
                            jacoco(
                                execPattern: 'backend/**/build/jacoco/*.exec',
                                classPattern: 'backend/**/build/classes',
                                sourcePattern: 'backend/**/src/main/java'
                            )
                        }
                    }
                }
                stage('Frontend Tests') {
                    steps {
                        dir('frontend') {
                            sh '''
                                npm ci
                                npm test -- --no-watch --no-progress --browsers=ChromeHeadless
                            '''
                        }
                    }
                }
            }
        }

        stage('Checkstyle') {
            steps {
                dir('backend') {
                    sh './gradlew checkstyleMain checkstyleTest --no-daemon --build-cache'
                }
            }
            post {
                always {
                    recordIssues(tools: [checkStyle(pattern: 'backend/**/build/reports/checkstyle/*.xml')])
                }
            }
        }

        stage('SonarQube Analysis') {
            when {
                anyOf {
                    branch 'main'
                    branch 'develop'
                }
            }
            steps {
                withSonarQubeEnv(env.SONARQUBE_SERVER) {
                    dir('backend') {
                        sh './gradlew sonar --no-daemon --build-cache'
                    }
                }
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build Docker Images') {
            when {
                expression { params.DEPLOY }
            }
            steps {
                script {
                    // All 14 backend service modules with their assigned ports
                    def modules = [
                        'lis-gateway'     : 8080,
                        'lis-patient'     : 8081,
                        'lis-order'       : 8082,
                        'lis-sample'      : 8083,
                        'lis-result'      : 8084,
                        'lis-report'      : 8085,
                        'lis-billing'     : 8086,
                        'lis-inventory'   : 8087,
                        'lis-instrument'  : 8088,
                        'lis-qc'          : 8089,
                        'lis-admin'       : 8090,
                        'lis-notification': 8091,
                        'lis-integration' : 8092,
                        'lis-auth'        : 8093
                    ]

                    def targetModules = modules
                    if (params.MODULE != 'all') {
                        targetModules = modules.subMap([params.MODULE])
                    }

                    targetModules.each { module, port ->
                        sh """
                            docker build \
                                --file infrastructure/docker/Dockerfile.backend \
                                --build-arg MODULE=${module} \
                                --build-arg PORT=${port} \
                                --tag ${DOCKER_REGISTRY}/${APP_NAME}/${module}:${env.IMAGE_TAG} \
                                --tag ${DOCKER_REGISTRY}/${APP_NAME}/${module}:latest \
                                backend/
                        """
                    }

                    // Frontend
                    if (params.MODULE == 'all' || params.MODULE == 'frontend') {
                        sh """
                            docker build \
                                --file infrastructure/docker/Dockerfile.frontend \
                                --tag ${DOCKER_REGISTRY}/${APP_NAME}/frontend:${env.IMAGE_TAG} \
                                --tag ${DOCKER_REGISTRY}/${APP_NAME}/frontend:latest \
                                frontend/
                        """
                    }
                }
            }
        }

        stage('Push Docker Images') {
            when {
                expression { params.DEPLOY }
            }
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-registry', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    sh "echo \${DOCKER_PASS} | docker login ${DOCKER_REGISTRY} -u \${DOCKER_USER} --password-stdin"

                    script {
                        def allModules = [
                            'lis-gateway', 'lis-patient', 'lis-order', 'lis-sample',
                            'lis-result', 'lis-report', 'lis-billing', 'lis-inventory',
                            'lis-instrument', 'lis-qc', 'lis-admin', 'lis-notification',
                            'lis-integration', 'lis-auth'
                        ]

                        def targetModules = allModules
                        if (params.MODULE != 'all' && params.MODULE != 'frontend') {
                            targetModules = [params.MODULE]
                        }

                        targetModules.each { module ->
                            sh "docker push ${DOCKER_REGISTRY}/${APP_NAME}/${module}:${env.IMAGE_TAG}"
                            sh "docker push ${DOCKER_REGISTRY}/${APP_NAME}/${module}:latest"
                        }

                        // Push frontend image
                        if (params.MODULE == 'all' || params.MODULE == 'frontend') {
                            sh "docker push ${DOCKER_REGISTRY}/${APP_NAME}/frontend:${env.IMAGE_TAG}"
                            sh "docker push ${DOCKER_REGISTRY}/${APP_NAME}/frontend:latest"
                        }
                    }
                }
            }
        }

        stage('Deploy') {
            when {
                allOf {
                    expression { params.DEPLOY }
                    anyOf {
                        branch 'main'
                        branch 'develop'
                        branch 'release/*'
                    }
                }
            }
            steps {
                script {
                    def namespace
                    switch (params.ENVIRONMENT) {
                        case 'production':
                            namespace = 'lis-prod'
                            break
                        case 'staging':
                            namespace = 'lis-staging'
                            break
                        default:
                            namespace = 'lis-dev'
                    }

                    def deployments = [
                        'lis-gateway', 'lis-patient', 'lis-order', 'lis-sample',
                        'lis-result', 'lis-report', 'lis-billing', 'lis-inventory',
                        'lis-instrument', 'lis-qc', 'lis-admin', 'lis-notification',
                        'lis-integration', 'lis-auth', 'lis-frontend'
                    ]

                    if (params.MODULE != 'all') {
                        deployments = [params.MODULE]
                    }

                    deployments.each { svc ->
                        def image = svc == 'lis-frontend' ? 'frontend' : svc
                        def container = svc.replace('lis-', '')
                        sh """
                            kubectl --namespace=${namespace} set image deployment/${svc} \
                                ${container}=${DOCKER_REGISTRY}/${APP_NAME}/${image}:${env.IMAGE_TAG}
                        """
                    }

                    // Wait for rollouts to complete
                    deployments.each { svc ->
                        sh "kubectl --namespace=${namespace} rollout status deployment/${svc} --timeout=300s"
                    }
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "✅ Build ${env.BUILD_NUMBER} succeeded!"
        }
        failure {
            emailext(
                subject: "❌ LIS Build FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """Build failed for ${APP_NAME}.
                    |Job: ${env.JOB_NAME}
                    |Build: #${env.BUILD_NUMBER}
                    |Branch: ${env.BRANCH_NAME}
                    |Commit: ${env.GIT_COMMIT_SHORT}
                    |Console: ${env.BUILD_URL}console""".stripMargin(),
                to: "${env.CHANGE_AUTHOR_EMAIL}"
            )
        }
    }
}
