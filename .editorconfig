root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 120

[*.{json,yml,yaml,xml,html,css,scss}]
indent_size = 2

[*.{ts,js}]
indent_size = 2
quote_type = single

[*.{kt,kts}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
